{
  "name": "ai-rpg-engine",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Simulation-native toolkit for building, analyzing, and balancing RPG worlds",
  "keywords": ["rpg", "game-engine", "simulation", "worldbuilding", "procedural", "ai", "text-rpg", "deterministic"],
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/ai-rpg-engine/issues"
  },
  "homepage": "https://mcp-tool-shop-org.github.io/ai-rpg-engine/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/ai-rpg-engine.git"
  },
  "author": "mcp-tool-shop",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
