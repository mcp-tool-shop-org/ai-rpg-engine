{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true
  },
  "include": [],
  "exclude": ["vitest.config.ts"],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/content-schema" },
    { "path": "packages/modules" },
    { "path": "packages/terminal-ui" },
    { "path": "packages/cli" },
    { "path": "packages/starter-fantasy" },
    { "path": "packages/starter-cyberpunk" },
    { "path": "packages/ollama" },
    { "path": "packages/presentation" },
    { "path": "packages/audio-director" },
    { "path": "packages/soundpack-core" },
    { "path": "packages/campaign-memory" },
    { "path": "packages/rumor-system" },
    { "path": "packages/starter-detective" },
    { "path": "packages/starter-pirate" },
    { "path": "packages/starter-zombie" },
    { "path": "packages/pack-registry" },
    { "path": "packages/starter-weird-west" },
    { "path": "packages/starter-colony" },
    { "path": "packages/character-creation" },
    { "path": "packages/asset-registry" }
  ]
